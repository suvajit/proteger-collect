# PostgreSQL
DATABASE_URL=postgresql://proteger:proteger_dev@localhost:5432/proteger_collect

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed credentials (read by seed script, never hardcoded)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@123!
SEED_SUPERVISOR_USERNAME=supervisor
SEED_SUPERVISOR_PASSWORD=Super@123!

# Storage
UPLOAD_DIR=./uploads
PHOTO_URL_BASE=http://localhost:3000/photos

# App
PORT=3000
NODE_ENV=development
