# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/proteger_collect"

# JWT
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
# Access token lifetime (default 15m), Refresh token lifetime (default 7d)
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000

# --- Photo uploads ---
# Base URL used to build photo URLs returned to clients.
# Must match the public URL of this server + /photos path.
# Example for production: https://jssapi.proteger.one/photos
PHOTO_URL_BASE="http://localhost:3000/photos"

# Optional: override the uploads directory (defaults to <cwd>/uploads)
# UPLOAD_DIR="/var/www/proteger/uploads"

# --- Email notifications ---
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your@email.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Proteger Collect <your@email.com>"
# Notification recipient — set via Admin Portal > Settings
# NOTIFICATION_EMAIL="admin@example.com"

# --- Seed credentials (only used by db:seed) ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="Admin@123!"
SUPERVISOR_USERNAME="supervisor"
SUPERVISOR_PASSWORD="Super@123!"
